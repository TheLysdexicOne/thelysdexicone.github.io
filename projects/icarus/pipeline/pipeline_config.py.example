# Icarus Data Pipeline — Machine-Specific Configuration
#
# This file is the template. The actual pipeline_config.py is committed to the
# repo for backup and portability. Update pipeline_config.py for your machine.
#
# PATH GUIDE
#   ICARUS_DATA_VERSIONS_DIR — root directory containing one subfolder per game version
#                              (e.g. .../icarus-data/versions/). The latest subfolder
#                              (by mtime) is selected automatically at runtime.
#   OUT_DIR_BASE             — base output directory; the resolved version name is
#                              appended as a subfolder automatically.
#   ASSETS_DEST_DIR          — where mirrored WebP icons are written (not version-specific).

# Root of all versioned icarus-data extractions.
ICARUS_DATA_VERSIONS_DIR = r"C:\path\to\icarus-data\versions"

# Base output directory — version subfolder appended automatically.
OUT_DIR_BASE    = r"C:\Projects\thelysdexicone.github.io\projects\icarus\public\data"

# WebP icon output — not version-specific.
ASSETS_DEST_DIR = r"C:\Projects\thelysdexicone.github.io\projects\icarus\public\game-assets"
